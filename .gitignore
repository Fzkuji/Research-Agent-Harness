__pycache__/
*.pyc
*.pyo
.venv/
.env
*.egg-info/
dist/
build/
.pytest_cache/
.DS_Store

# Tooling cache
.openprogram/

# Generated research artifacts at repo root (keep README/SKILL).
# NOTE: blanket ignore — any new legitimate root doc (CHANGELOG.md,
# CONTRIBUTING.md, ...) needs its own `!` entry below or git add will
# silently do nothing.
/*.md
/*.tex
!/README.md
!/SKILL.md

# Archived outputs from past test runs
/_archive/

# Result directories from past runs
/auto_review/
/experiment_results/
/idea_results/
/literature_results/
/test/
/test_research_project/

# Review/codex temp working dirs (must never be committed — they hold paper text)
review_artifact_*/
detailed_draft_*/
review_stage2_*/
extract_judgment_*/
.claude/scheduled_tasks.lock
